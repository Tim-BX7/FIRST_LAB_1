<%- include('../partials/header', { title }) %>
<section class="grid-two">
  <article class="card">
    <h1>Email Template Preview</h1>
    <form method="post" action="/admin/email/preview" class="stack">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <textarea name="template" rows="10"><%= template %></textarea>
      <button class="button" type="submit">Render Preview</button>
    </form>
    <p class="muted">Available merge values include <code>user</code> and <code>company</code>.</p>
  </article>

  <article class="card">
    <h2>Preview Output</h2>
    <div class="preview"><%= preview %></div>
  </article>
</section>
<%- include('../partials/footer') %>
