<%- include('partials/header', { title }) %>
<section class="card">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Project</p>
      <h1><%= project.name %></h1>
    </div>
    <span class="pill"><%= project.status %></span>
  </div>
  <p><%= project.description %></p>
  <p class="muted">Budget: <%= formatMoney(project.budget_cents) %></p>
</section>

<section class="grid-two">
  <article class="card">
    <h2>Comments</h2>
    <% comments.forEach((comment) => { %>
      <div class="comment">
        <strong><%= comment.display_name %></strong>
        <div class="unsafe"><%- comment.body %></div>
      </div>
    <% }) %>
  </article>

  <article class="card">
    <h2>Add Comment</h2>
    <form method="post" action="/projects/<%= project.id %>/comments" class="stack">
      <textarea name="body" rows="6" placeholder="Share status, feedback, or snippets"></textarea>
      <button class="button" type="submit">Post Comment</button>
    </form>
    <p class="muted">Moderation marker: <code><%= flags.xss_stored %></code></p>
  </article>
</section>
<%- include('partials/footer') %>
